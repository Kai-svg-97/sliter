{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "sliter",
  "version": "0.1.11",
  "identifier": "com.kai.sliter",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "sliter — SQLite editor",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE4NTEzNUE2NUNGRkJBNjMKUldSanV2OWNwalZSR0ErN1FxTGRJd3Y4eTEyNTBuL3c2cmFRWTVzN09jdElIdi9EaUd1ZEJQWi8K",
      "endpoints": [
        "https://github.com/Kai-svg-97/sliter/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
